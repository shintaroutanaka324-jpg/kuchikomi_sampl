# Supabase Edge Functions 用（Dashboard → Edge Functions → Secrets に設定）
# ローカル開発: supabase functions serve --env-file supabase/functions/.env

STRIPE_SECRET_KEY=sk_test_REPLACE_WITH_YOUR_KEY
STRIPE_PRICE_ID=price_REPLACE_WITH_YOUR_PRICE_ID
STRIPE_WEBHOOK_SECRET=whsec_REPLACE_WITH_YOUR_WEBHOOK_SECRET
SUPABASE_SERVICE_ROLE_KEY=REPLACE_WITH_SERVICE_ROLE_KEY

# 以下は Supabase が自動注入（ローカルでは supabase status で確認）
# SUPABASE_URL=
# SUPABASE_ANON_KEY=
